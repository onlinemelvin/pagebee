#!/bin/bash
set -e

echo "🚀 Running pre-push checks..."

# Workflow: feature work lands on `development`; `main` is updated by merging
# `development` and pushing directly. Direct pushes to main are allowed by design.

# ── 2. Full test suite ───────────────────────────────────────────────────────
echo "→ Running full test suite..."
npx vitest run

# ── 3. Build check ───────────────────────────────────────────────────────────
echo "→ Checking build..."
npx next build

echo "✅ Pre-push checks passed."
