// =============================================================================
// PageBee — Prisma Schema
// =============================================================================
// Multi-tenant shared-services platform. See docs/ARCHITECTURE.md for the
// reasoning behind ownership levels, tenant scoping, and the dual-purpose
// payment ledger. Every client-business-owned table carries `clientId` and is
// indexed on it — that column is the tenant boundary enforced in the service
// layer on every query.
//
// Ownership levels (see ARCHITECTURE.md §Ownership):
//   PLATFORM  — owned by our company (employees, payroll, company finances)
//   CLIENT    — owned by a local-business tenant (leads, bookings, customers)
//   CUSTOMER  — an end-customer of a client business (always clientId-scoped)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase Postgres. Runtime uses the pooled (PgBouncer, port 6543) connection;
  // migrations need a direct (port 5432) connection. See docs/ARCHITECTURE.md §11.
  url       = env("DATABASE_URL") // pooled: ...pooler.supabase.com:6543/...?pgbouncer=true
  directUrl = env("DIRECT_URL")   // direct: ...supabase.com:5432/postgres
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserType {
  PLATFORM // staff: admins, employees, sales reps, support agents
  CLIENT   // a client business owner / staff logging into their dashboard
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum EmployeeType {
  SALARIED
  HOURLY
  COMMISSION_REP
  CONTRACTOR
  SUPPORT_AGENT
  ADMIN
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum CompensationType {
  SALARY
  HOURLY
  COMMISSION
  MIXED
}

enum PlanName {
  LAUNCH
  CONNECT
  AUTOMATE
}

enum SubscriptionStatus {
  TRIAL
  SETUP_PENDING
  ACTIVE
  PAST_DUE
  PAYMENT_FAILED
  SUSPENDED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BOOKED
  WON
  LOST
  SPAM
}

enum LeadType {
  CONTACT_FORM
  QUOTE_REQUEST
  SERVICE_INQUIRY
}

enum QuoteStatus {
  DRAFT
  NEEDS_APPROVAL
  APPROVED
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum ConversationChannel {
  WEBSITE_CHAT
  EMAIL
  SMS
}

enum MessageSenderType {
  CUSTOMER
  OWNER
  EMPLOYEE
  AI
  SYSTEM
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CLIENT
  WAITING_ON_ADMIN
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Distinguishes invoices we raise against clients (our revenue) from invoices a
// client business raises against its own end customers (their revenue, via
// Stripe Connect). See ARCHITECTURE.md §Payment ledger.
enum InvoiceKind {
  PLATFORM_BILLING // PageBee billing a client business (Stripe Billing)
  CLIENT_CUSTOMER  // a client billing its customer (Connect Express destination charge)
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  REFUNDED
  ACCEPTED // estimate/quote accepted by the customer
  DECLINED // estimate/quote declined
  EXPIRED  // estimate/quote past its expiry
}

// A client→customer financial document. Estimates convert to Quotes, Quotes to Invoices;
// all three share line items, discounts, and tax (see the Invoice model).
enum FinanceDocType {
  ESTIMATE
  QUOTE
  INVOICE
}

enum DiscountType {
  PERCENT // value is basis points (850 = 8.50%)
  FIXED   // value is cents
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum AiMode {
  SUGGESTION
  AUTO_REPLY
  HYBRID
}

enum AiActionType {
  DRAFT_REPLY
  AUTO_REPLY
  SUMMARIZE
  FOLLOW_UP
  LEAD_SCORE
  INVOICE_REMINDER
  GENERATE_WEBSITE
}

enum AiEscalationReason {
  CUSTOM_PRICING
  ANGRY_CUSTOMER
  LEGAL_QUESTION
  MEDICAL_QUESTION
  FINANCIAL_QUESTION
  REFUND_REQUEST
  DISCOUNT_REQUEST
  UNKNOWN_TO_KB
  GUARANTEED_AVAILABILITY
  EMERGENCY_SERVICE
  PAYMENT_DISPUTE
  PAYMENT_CLAIM_UNVERIFIED
  LOW_CONFIDENCE
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum CommissionStatus {
  PENDING
  ELIGIBLE
  APPROVED
  PAID
  CLAWED_BACK
}

enum ContractType {
  CLIENT_SERVICE
  EMPLOYEE
  CONTRACTOR
  SALES_REP_COMMISSION
  NDA
  SUPPORT_SERVICE
  MAINTENANCE
  VENDOR
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  TERMINATED
}

enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum NotificationChannel {
  EMAIL
  SMS
  DASHBOARD
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  FAILED
  OPENED
}

enum ConsentChannel {
  EMAIL
  SMS
}

enum WebsiteJobStatus {
  QUEUED
  GENERATING
  NEEDS_REVIEW
  PUBLISHED
  FAILED
}

enum WebsiteVersionStatus {
  DRAFT
  PREVIEW
  PUBLISHED
  ARCHIVED
}

// Figma-style review annotations on a generated site version.
enum ReviewActorType {
  ADMIN    // platform admin
  REVIEWER // platform reviewer/contractor (website:review permission)
  CLIENT   // the tenant business owner, in preview mode
  SYSTEM
}

enum ReviewCommentKind {
  CHANGE_REQUEST // compiled into the next regeneration
  NOTE           // informational only
}

enum ReviewCommentStatus {
  OPEN
  RESOLVED
  WONT_FIX
}

// =============================================================================
// PLATFORM OPERATIONS — owned by our company
// =============================================================================

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?
  supabaseUserId String?    @unique // links to Supabase Auth user (identity lives there)
  name           String
  type         UserType
  status       UserStatus @default(INVITED)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles      UserRole[]
  employee   Employee?
  clientUser ClientUser?
  auditLogs  AuditLog[]

  @@index([type])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. ADMIN, SALES_REP, SUPPORT_AGENT, CLIENT_OWNER
  description String?
  createdAt   DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "lead:read", "quote:approve", "payroll:write"
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Employee {
  id               String           @id @default(cuid())
  userId           String?          @unique
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  employeeType     EmployeeType
  compensationType CompensationType
  employmentStatus EmploymentStatus @default(ACTIVE)
  title            String?
  startDate        DateTime
  endDate          DateTime?
  managerId        String?
  manager          Employee?        @relation("EmployeeManager", fields: [managerId], references: [id])
  reports          Employee[]       @relation("EmployeeManager")

  // Compensation references — actual payouts handled by a payroll provider later.
  baseSalary    Decimal? @db.Decimal(12, 2)
  hourlyRate    Decimal? @db.Decimal(12, 2)
  payrollRef    String? // external payroll-provider id (Gusto/QuickBooks/ADP)
  taxInfoRef    String? // pointer to securely-held tax/payment info, never raw data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollRecords    PayrollRecord[]
  commissionRecords CommissionRecord[]
  salesAssignments  SalesAssignment[]
  contracts         Contract[]
  quotesCreated     Quote[]            @relation("QuoteSalesRep")

  @@index([employeeType])
  @@index([managerId])
  @@map("employees")
}

model PayPeriod {
  id        String          @id @default(cuid())
  label     String // e.g. "2026-06 1st half"
  startDate DateTime
  endDate   DateTime
  status    PayrollStatus   @default(DRAFT)
  records   PayrollRecord[]
  createdAt DateTime        @default(now())

  @@map("pay_periods")
}

model PayrollRecord {
  id          String        @id @default(cuid())
  payPeriodId String
  payPeriod   PayPeriod     @relation(fields: [payPeriodId], references: [id])
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id])
  status      PayrollStatus @default(DRAFT)

  grossSalary    Decimal @default(0) @db.Decimal(12, 2)
  hoursWorked    Decimal @default(0) @db.Decimal(8, 2)
  hourlyPay      Decimal @default(0) @db.Decimal(12, 2)
  commissionPay  Decimal @default(0) @db.Decimal(12, 2)
  bonus          Decimal @default(0) @db.Decimal(12, 2)
  deductions     Decimal @default(0) @db.Decimal(12, 2)
  reimbursements Decimal @default(0) @db.Decimal(12, 2)
  netPay         Decimal @default(0) @db.Decimal(12, 2)

  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([employeeId])
  @@index([payPeriodId])
  @@map("payroll_records")
}

model CommissionPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  active      Boolean  @default(true)

  // Base commission per closed deal by plan.
  launchBase   Decimal @default(25) @db.Decimal(12, 2)
  connectBase  Decimal @default(50) @db.Decimal(12, 2)
  automateBase Decimal @default(75) @db.Decimal(12, 2)

  // Optional recurring commission (e.g. 5% of monthly revenue for N months).
  recurringPct    Decimal @default(0) @db.Decimal(5, 2)
  recurringMonths Int     @default(0)

  // Clawback window in days (e.g. 30) — commission reversed if client cancels.
  clawbackDays Int @default(30)

  records   CommissionRecord[]
  createdAt DateTime           @default(now())

  @@map("commission_plans")
}

model CommissionRecord {
  id               String           @id @default(cuid())
  planId           String
  plan             CommissionPlan   @relation(fields: [planId], references: [id])
  employeeId       String
  employee         Employee         @relation(fields: [employeeId], references: [id])
  clientId         String? // the closed client this commission is tied to
  client           Client?          @relation(fields: [clientId], references: [id])
  status           CommissionStatus @default(PENDING)

  // Always computed from actual collected revenue, never listed pricing.
  basis            String // e.g. "setup_fee", "recurring_month_3"
  collectedRevenue Decimal @db.Decimal(12, 2)
  amount           Decimal @db.Decimal(12, 2)

  eligibleAt   DateTime?
  approvedById String?
  approvedAt   DateTime?
  paidAt       DateTime?
  clawedBackAt DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([employeeId])
  @@index([clientId])
  @@index([status])
  @@map("commission_records")
}

model Contract {
  id            String         @id @default(cuid())
  type          ContractType
  status        ContractStatus @default(DRAFT)
  title         String
  documentUrl   String? // object-storage pointer to signed PDF
  templateKey   String? // if generated from a template

  // Polymorphic-ish links — at most one is set depending on type.
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id])
  vendorName String?

  compensationTerms String?
  commissionTerms   String?
  effectiveDate     DateTime?
  renewalDate       DateTime?
  terminationDate   DateTime?
  signedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([renewalDate])
  @@map("contracts")
}

// Bills we owe to vendors (Resend, Twilio, hosting, contractors, software...).
model VendorInvoice {
  id          String     @id @default(cuid())
  vendorName  String
  reference   String?
  amount      Decimal    @db.Decimal(12, 2)
  currency    String     @default("usd")
  status      BillStatus @default(UNPAID)
  dueDate     DateTime?
  paidAt      DateTime?
  receiptUrl  String?
  isRecurring Boolean    @default(false)
  category    String? // "software", "hosting", "telecom", "contractor"...
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([dueDate])
  @@map("vendor_invoices")
}

// Invoices our company issues (rare; e.g. one-off custom work billed manually).
model CompanyInvoice {
  id         String        @id @default(cuid())
  number     String        @unique
  billToName String
  amount     Decimal       @db.Decimal(12, 2)
  currency   String        @default("usd")
  status     InvoiceStatus @default(DRAFT)
  dueDate    DateTime?
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("company_invoices")
}

model CompanyExpense {
  id          String   @id @default(cuid())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("usd")
  category    String?
  incurredOn  DateTime
  isRecurring Boolean  @default(false)
  receiptUrl  String?
  createdAt   DateTime @default(now())

  @@index([incurredOn])
  @@map("company_expenses")
}

model InternalDocument {
  id        String   @id @default(cuid())
  title     String
  url       String
  category  String?
  createdAt DateTime @default(now())

  @@map("internal_documents")
}

// Append-only audit trail. Every sensitive action writes here.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  clientId   String? // tenant context, if applicable
  action     String // e.g. "quote.approved", "invoice.voided"
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// =============================================================================
// SALES / CRM — owned by our company
// =============================================================================

model Prospect {
  id           String   @id @default(cuid())
  businessName String
  contactName  String?
  email        String?
  phone        String?
  businessType String?
  source       String? // "cold_call", "seo", "ads", "referral"...
  status       String   @default("new") // new, contacted, qualified, closed, lost
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities  ProspectActivity[]
  callNotes   CallNote[]
  followUps   FollowUp[]
  assignments SalesAssignment[]
  quotes      Quote[]
  convertedClient Client? @relation("ProspectToClient")

  @@index([status])
  @@map("prospects")
}

model ProspectActivity {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type       String // "call", "email", "meeting", "note"
  summary    String
  createdById String?
  createdAt  DateTime @default(now())

  @@index([prospectId])
  @@map("prospect_activities")
}

model CallNote {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  outcome    String? // "no_answer", "interested", "callback", "not_interested"
  note       String
  createdById String?
  createdAt  DateTime @default(now())

  @@index([prospectId])
  @@map("call_notes")
}

model FollowUp {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  dueAt      DateTime
  completed  Boolean  @default(false)
  note       String?
  assignedToId String?
  createdAt  DateTime @default(now())

  @@index([prospectId])
  @@index([dueAt])
  @@map("follow_ups")
}

model SalesAssignment {
  id         String   @id @default(cuid())
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([prospectId, employeeId])
  @@index([employeeId])
  @@map("sales_assignments")
}

model Quote {
  id           String      @id @default(cuid())
  prospectId   String
  prospect     Prospect    @relation(fields: [prospectId], references: [id])
  salesRepId   String
  salesRep     Employee    @relation("QuoteSalesRep", fields: [salesRepId], references: [id])
  status       QuoteStatus @default(DRAFT)
  plan         PlanName

  // Pricing snapshot — listed vs offered, in cents to avoid float drift.
  listedSetupFee     Int
  listedMonthlyFee   Int
  offeredSetupFee    Int
  offeredMonthlyFee  Int
  discountReason     String?

  contractLengthMonths Int?
  expiresAt            DateTime?
  customerNotes        String? // shown to prospect
  internalNotes        String? // staff only

  // Set true by the pricing-rule engine when offer is outside rep guardrails.
  requiresApproval Boolean @default(false)

  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  rejectedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lineItems  QuoteLineItem[]
  discounts  QuoteDiscount[]
  approvals  QuoteApproval[]
  client     Client?         @relation("QuoteToClient")

  @@index([prospectId])
  @@index([salesRepId])
  @@index([status])
  @@map("quotes")
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  kind        String // "addon", "feature", "usage_limit", "fee"
  quantity    Int     @default(1)
  unitAmount  Int     @default(0) // cents
  recurring   Boolean @default(false)

  @@index([quoteId])
  @@map("quote_line_items")
}

model QuoteDiscount {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  target      String // "setup_fee" | "monthly_fee"
  reason      String
  amount      Int // cents discounted
  requiresApproval Boolean @default(false)

  @@index([quoteId])
  @@map("quote_discounts")
}

model QuoteApproval {
  id          String         @id @default(cuid())
  quoteId     String
  quote       Quote          @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  status      ApprovalStatus @default(PENDING)
  approverId  String? // admin User id
  decisionAt  DateTime?
  comment     String?
  createdAt   DateTime       @default(now())

  @@index([quoteId])
  @@index([status])
  @@map("quote_approvals")
}

// =============================================================================
// CLIENT MANAGEMENT — the tenants
// =============================================================================

model Plan {
  id           String   @id @default(cuid())
  name         PlanName @unique
  setupFee     Int // cents
  monthlyFee   Int // cents
  maxPages     Int
  monthlyUpdates Int
  // Canonical feature flag set for this plan (see docs/FEATURE_FLAGS.md).
  featureFlags Json
  active       Boolean  @default(true)

  subscriptions Subscription[]

  @@map("plans")
}

model Client {
  id            String   @id @default(cuid())
  businessName  String
  businessType  String?
  slug          String   @unique // tenant slug used internally
  ownerName     String?
  ownerEmail    String?
  ownerPhone    String?
  status        String   @default("active") // active, suspended, churned
  isTest        Boolean  @default(false) // test signup (email @test.com) — skips paid setup

  // Stripe Connect (Express) — set once the client completes payout onboarding.
  // PageBee collects via destination charges; funds settle to this account.
  stripeConnectAccountId String?  @unique
  paymentsEnabled        Boolean  @default(false) // charges_enabled && payouts_enabled

  // Conversion provenance.
  prospectId String?   @unique
  prospect   Prospect? @relation("ProspectToClient", fields: [prospectId], references: [id])
  sourceQuoteId String? @unique
  sourceQuote   Quote?  @relation("QuoteToClient", fields: [sourceQuoteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         ClientUser[]
  subscription  Subscription?
  settings      ClientSetting?
  websites      Website[]
  customers     Customer[]
  leads         Lead[]
  bookings      Booking[]
  conversations Conversation[]
  invoices      Invoice[]
  recurringPlans RecurringPlan[]
  payments      Payment[]
  statements    Statement[]
  dues          Due[]
  accountBalances AccountBalance[]
  supportTickets SupportTicket[]
  aiKnowledgeBase AiKnowledgeBase?
  contracts      Contract[]
  commissionRecords CommissionRecord[]
  analyticsEvents AnalyticsEvent[]
  previews        Preview[]        @relation("ClientPreviews")
  media           ClientMedia[]
  websiteUpdates  WebsiteUpdate[]
  upgradeRequests UpgradeRequest[]
  services        Service[]
  taxRates        TaxRate[]
  userInvites     ClientUserInvite[]
  usageRecords    UsageRecord[]

  @@index([status])
  @@map("clients")
}

// A client-initiated change to a LIVE (already published) site. Each one consumes a
// monthly update from the plan's `monthlyUpdates` allowance — the count of these rows in
// the current period is the quota usage. Distinct from pre-launch preview revisions.
model WebsiteUpdate {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  websiteId String
  versionId String? // the new WebsiteVersion this update produced (once generated)
  note      String
  status    String   @default("requested") // requested | in_review | published | rejected
  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@map("website_updates")
}

// A real-account upgrade intent captured for admin/sales to apply (interim, pre-Stripe).
// Test accounts upgrade instantly and never create one of these.
model UpgradeRequest {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromPlan    String
  toPlan      String
  reason      String? // "appointments" | "more_updates" | ...
  status      String   @default("requested") // requested | applied | declined
  appliedById String?
  createdAt   DateTime @default(now())

  @@index([status])
  @@map("upgrade_requests")
}

// Account-level reusable media library. Images a client uploads here (or via the
// website intake) persist independently of any single site/version, so they can be
// reused or updated across regenerations. Stored in the same public bucket as uploads.
model ClientMedia {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  url       String
  name      String?
  alt       String?
  kind      String   @default("image") // image, logo, document
  inGallery Boolean  @default(true) // whether this image appears in the public photo gallery
  createdAt DateTime @default(now())

  @@index([clientId])
  @@map("client_media")
}

model ClientUser {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("owner") // owner, staff
  createdAt DateTime @default(now())

  @@index([clientId])
  @@map("client_users")
}

// Metered usage for resources without a natural source table (AI replies, SMS, email).
// Invoices are counted from the Invoice table directly; these are recorded per send.
model UsageRecord {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  key       String // aiReplies | sms | email
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([clientId, key, createdAt])
  @@map("usage_records")
}

// A pending invitation for someone to join a client's team (Automate multi-user).
// Accepting links the invitee's user to the client via a ClientUser row.
model ClientUserInvite {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email      String
  role       String    @default("staff") // owner, staff
  token      String    @unique
  status     String    @default("pending") // pending, accepted, revoked
  invitedBy  String? // userId of the inviter
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([clientId])
  @@index([email])
  @@map("client_user_invites")
}

model Subscription {
  id        String             @id @default(cuid())
  clientId  String             @unique
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan               @relation(fields: [planId], references: [id])
  status    SubscriptionStatus @default(SETUP_PENDING)

  // Pricing actually agreed (may differ from list price via approved quote), cents.
  agreedSetupFee   Int
  agreedMonthlyFee Int
  setupFeePaid     Boolean   @default(false)
  setupFeePaidAt   DateTime?

  // Stripe Billing references (our company billing the client).
  stripeCustomerId     String?
  stripeSubscriptionId String?

  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAt           DateTime?
  cancelledAt        DateTime?
  failedPaymentCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("subscriptions")
}

// Per-client overrides on top of the plan's canonical flags (add-ons, custom deals).
model FeatureFlag {
  id        String   @id @default(cuid())
  clientId  String
  key       String
  enabled   Boolean
  value     Json? // for numeric limits e.g. { "smsIncludedMonthly": 150 }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
  @@index([clientId])
  @@map("feature_flags")
}

model ClientSetting {
  id       String  @id @default(cuid())
  clientId String  @unique
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  businessHours   Json? // [{ day, open, close }]
  services        Json? // [{ name, description, price? }]
  faqs            Json? // [{ q, a }]
  serviceAreas    Json? // [string]
  branding        Json? // { primaryColor, secondaryColor, fontStyle, logoUrl }
  aiSettings      Json? // { mode, escalationRules, tone }
  paymentSettings Json? // { depositPct, applicationFeePct, absorbStripeFees }
  calendarSettings Json? // { provider, externalCalendarId, availabilityRules }
  financeSettings Json? // { numberPrefixes, defaultTerms, defaultNotes, currency, reminders, lateFee, stripeMode }
  smsSettings     Json?
  emailSettings   Json?

  updatedAt DateTime @updatedAt

  @@map("client_settings")
}

// =============================================================================
// WEBSITE GENERATION
// =============================================================================

model Website {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Every site is reachable at {subdomain}.pagebee.com; Connect/Automate may add a
  // custom domain provisioned through the Vercel Domains API (see ARCHITECTURE §11).
  subdomain    String?  @unique // tenant slug host, e.g. acme.pagebee.com
  // Custom domains (Connect/Automate) live in the WebsiteDomain table below — a connection
  // provisions a host PAIR (apex + www) so both resolve here, one redirecting to the other.
  siteToken    String   @unique // public API key for this site's calls
  status       String   @default("draft") // draft, preview, published

  // The owner's chosen primary call-to-action (e.g. "Request a quote"). Set from the intake at
  // generation and editable any time from the Inquiries page with NO rebuild — it drives the live
  // site's CTA button label, the form's submit label, and the lead `type` at serve time (see
  // src/lib/site/lead-goals.ts + the /api/v1/public/lead-form endpoint). Null → use whatever the
  // form was generated with.
  leadFormGoal String?

  publishedVersionId String?  @unique
  publishedVersion   WebsiteVersion? @relation("PublishedVersion", fields: [publishedVersionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions       WebsiteVersion[] @relation("WebsiteVersions")
  generationJobs WebsiteGenerationJob[]
  assets         WebsiteAsset[]
  visits         WebsiteVisit[]
  domains        WebsiteDomain[]

  @@index([clientId])
  @@map("websites")
}

// A single custom-domain host attached to a site (Connect/Automate). One owner "connect" creates a
// PAIR of rows — the apex (e.g. acme.com) and its www (www.acme.com) — with one marked primary
// (canonical) and the other set to redirect to it on Vercel. Other subdomains (book.acme.com) are a
// lone row. Lifecycle per host: requested → verifying → active (error on failure). Admin approval
// happens at the pair level. See src/lib/modules/website/domain.ts + ARCHITECTURE §11.
model WebsiteDomain {
  id        String  @id @default(cuid())
  websiteId String
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  host      String  @unique // fully-qualified host, e.g. acme.com or www.acme.com
  kind      String // "apex" | "www" | "subdomain"
  isPrimary Boolean @default(false) // the canonical host; its sibling redirects here

  // requested → owner submitted, awaiting admin approval (NOT yet on Vercel)
  // verifying → on the Vercel project, DNS not yet resolving · active → verified + SSL · error
  status       String
  verification Json? // DNS records to set: { records: [{type,name,value}], txt?: [...] }
  error        String? // last failure reason for this host

  requestedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([websiteId])
  @@index([status])
  @@map("website_domains")
}

model WebsiteVersion {
  id        String               @id @default(cuid())
  websiteId String
  website   Website              @relation("WebsiteVersions", fields: [websiteId], references: [id], onDelete: Cascade)
  version   Int
  status    WebsiteVersionStatus @default(DRAFT)
  createdAt DateTime             @default(now())

  // Code-generated mode: a complete self-contained HTML/Tailwind document that
  // calls PageBee's shared /api/v1/public/* endpoints for all dynamic features.
  generatedHtml String? @db.Text

  // The lead-capture form is built for every site at generation (so it matches the design) but
  // STRIPPED OUT of generatedHtml into here — the page keeps only a [data-pb-leadform-slot]. It's
  // injected back at serve time ONLY when the plan allows forms AND the owner enabled them, so the
  // page never ships a form to a tier/owner that shouldn't have one. See src/lib/site/lead-form.ts.
  leadFormHtml String? @db.Text

  // Same pattern as leadFormHtml, for the appointment booking TRIGGER section (heading + "Book…"
  // button). Stripped out of generatedHtml into here; the page keeps a [data-pb-booking-slot]. The
  // platform-owned modal (calendar + submit) is added at serve time, and the trigger is injected back
  // only when the plan allows booking AND the owner enabled it. See src/lib/site/booking.ts.
  bookingHtml String? @db.Text

  config WebsiteConfig?
  pages  WebsitePage[]
  publishedFor Website? @relation("PublishedVersion")
  reviewComments WebsiteReviewComment[]

  @@unique([websiteId, version])
  @@index([websiteId])
  @@map("website_versions")
}

// A pin-style review comment anchored to an element of a rendered version. Used by
// both platform reviewers (admin queue) and clients (preview markup). Anchors only
// need to be stable within a version's lifetime — a revision creates a new version.
model WebsiteReviewComment {
  id        String         @id @default(cuid())
  versionId String
  version   WebsiteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  parentId String?                @map("parent_id")
  parent   WebsiteReviewComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  WebsiteReviewComment[] @relation("CommentThread")

  authorType ReviewActorType
  authorId   String? // User.id (platform) or Client/ClientUser id; null for SYSTEM
  authorName String? // denormalized for display

  kind   ReviewCommentKind   @default(CHANGE_REQUEST)
  status ReviewCommentStatus @default(OPEN)

  // Element anchor (see serve.ts annotate bridge).
  pagePath   String  @default("/") // which routed sub-page the pin sits on
  selector   String? // CSS selector path to the target element
  anchorText String? // nearby text snippet, for human context + fallback matching
  x          Float? // fractional 0..1 position within the element
  y          Float?
  body       String

  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([versionId])
  @@index([versionId, status])
  @@index([parentId])
  @@map("website_review_comments")
}

model WebsiteConfig {
  id        String         @id @default(cuid())
  versionId String         @unique
  version   WebsiteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  theme            Json // { template, style, primaryColor, ... }
  copy             Json // { heroHeadline, aboutText, services, faqs, ... }
  enabledFeatures  Json // plan-validated feature toggles for this site
  apiIntegrations  Json // which shared APIs this site is wired to
  components       Json // ordered component list with props
  seoDefaults      Json?
  adminReviewed    Boolean @default(false)
  reviewedById     String?
  reviewedAt       DateTime?

  @@map("website_configs")
}

model WebsitePage {
  id              String         @id @default(cuid())
  versionId       String
  version         WebsiteVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  slug            String
  title           String
  seoTitle        String?
  metaDescription String?
  sections        Json // ordered section list
  order           Int            @default(0)

  @@unique([versionId, slug])
  @@index([versionId])
  @@map("website_pages")
}

model WebsiteAsset {
  id        String   @id @default(cuid())
  websiteId String
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  url       String
  kind      String // "image", "logo", "favicon", "document"
  alt       String?
  createdAt DateTime @default(now())

  @@index([websiteId])
  @@map("website_assets")
}

model WebsiteGenerationJob {
  id        String           @id @default(cuid())
  websiteId String
  website   Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status    WebsiteJobStatus @default(QUEUED)
  inputIntake Json // the intake form data fed to the generator
  output      Json? // structured website config produced by the AI service
  promptLog   Json? // EVALUATION (temporary): exact LLM prompt(s) for this draft; safe to drop later
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime         @default(now())

  @@index([websiteId])
  @@index([status])
  @@index([status, createdAt])
  @@map("website_generation_jobs")
}

// =============================================================================
// PREVIEW / ONBOARDING — "Preview before you pay" acquisition model.
// Free AI website preview -> approval -> setup fee -> launch -> subscription.
// See docs/ONBOARDING.md. Previews reuse the SAME generation + renderer; preview
// mode (banner, noindex, demo features) is controlled by flags until payment.
// =============================================================================

enum PreviewStatus {
  INTAKE_STARTED
  INTAKE_COMPLETED
  PREVIEW_GENERATING
  IN_REVIEW // generated, awaiting platform (admin) review before the client may see it
  PREVIEW_READY
  PREVIEW_SENT
  PREVIEW_VIEWED
  REVISION_REQUESTED
  REVISION_COMPLETED
  APPROVED
  SETUP_FEE_PENDING
  SETUP_FEE_PAID
  LAUNCH_IN_PROGRESS
  LIVE
  LOST
}

model Preview {
  id           String        @id @default(cuid())
  // Origin: a sales prospect and/or (once converted) a client. Both nullable so a
  // self-serve preview can exist before either record is created.
  prospectId   String?
  clientId     String?
  client       Client?       @relation("ClientPreviews", fields: [clientId], references: [id], onDelete: Cascade)
  websiteId    String?       @unique // the Website generated for this preview
  selectedPlan PlanName
  status       PreviewStatus @default(INTAKE_STARTED)

  previewUrl   String? // temporary host, e.g. {token}.preview.pagebee.com
  generatedAt  DateTime?
  sentAt       DateTime?
  viewedAt     DateTime?
  approvedAt   DateTime?

  revisionCount    Int @default(0)
  maxFreeRevisions Int @default(1) // one minor revision before payment

  createdById        String? // employee/user who created it (null = self-serve/system)
  assignedSalesRepId String? // Employee.id when sales-led
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions  PreviewRevision[]
  conversion Conversion?

  @@index([status])
  @@index([prospectId])
  @@index([clientId])
  @@index([clientId, createdAt])
  @@index([assignedSalesRepId])
  @@map("previews")
}

model PreviewRevision {
  id          String    @id @default(cuid())
  previewId   String
  preview     Preview   @relation(fields: [previewId], references: [id], onDelete: Cascade)
  requestedBy String? // "customer" or an Employee.id
  requestText String
  status      String    @default("requested") // requested, in_progress, completed
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([previewId])
  @@map("preview_revisions")
}

model Conversion {
  id           String   @id @default(cuid())
  previewId    String   @unique
  preview      Preview  @relation(fields: [previewId], references: [id], onDelete: Cascade)
  prospectId   String?
  clientId     String
  selectedPlan PlanName

  // Money in integer cents.
  setupFeeAmount Int
  monthlyAmount  Int
  discountAmount Int @default(0)

  setupFeePaidAt        DateTime?
  subscriptionStartedAt DateTime?
  convertedById         String? // Employee.id (sales) or null (self-serve)

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([prospectId])
  @@map("conversions")
}

// =============================================================================
// CUSTOMER MANAGEMENT — tenant-scoped (belongs to a client business)
// =============================================================================

model Customer {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   String?
  billingAddress Json? // structured { line1, city, state, postalCode, country } — used for Stripe Tax
  // CRM fields (owner-managed contact record). `company` for B2B/fleet accounts; `tags` for quick
  // segmentation ("VIP", "Regular"); `notes` a free-text memo; `customFields` an ordered list of
  // {label,value} for trade-specific details (vehicle/plate, preferred stylist, gate code, …) so the
  // record fits any small business without bespoke columns. `source` = how they were acquired
  // (manual, website, referral). `archivedAt` soft-hides a contact without losing their history.
  company     String?
  tags        String[] @default([])
  note        String?  @db.Text @map("notes") // quick free-text memo (distinct from the threaded `notes` relation)
  customFields Json?   // [{ label: string, value: string }]
  source      String?  // "manual" | "website" | "import" | "booking" | …
  archivedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consents      CustomerConsent[]
  notes         CustomerNote[]
  recurringPlans RecurringPlan[]
  leads         Lead[]
  bookings      Booking[]
  invoices      Invoice[]
  payments      Payment[]
  conversations Conversation[]
  statements    Statement[]
  accountBalance AccountBalance?

  @@index([clientId])
  @@index([clientId, email])
  @@index([clientId, archivedAt])
  @@map("customers")
}

model CustomerConsent {
  id         String        @id @default(cuid())
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel    ConsentChannel
  granted    Boolean
  grantedAt  DateTime?
  revokedAt  DateTime?
  source     String? // "website_form", "manual", "import"

  @@unique([customerId, channel])
  @@index([customerId])
  @@map("customer_consents")
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  body       String
  authorId   String?
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_notes")
}

// =============================================================================
// LEADS / BOOKING / CHAT — tenant-scoped
// =============================================================================

model Lead {
  id         String     @id @default(cuid())
  clientId   String
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])
  type       LeadType   @default(CONTACT_FORM)
  status     LeadStatus @default(NEW)

  name    String
  email   String?
  phone   String?
  message String?
  source  String? // page/url or campaign the lead came from
  payload Json? // raw form fields

  assignedToId String? // client-side staff or our staff
  aiScore      Int? // 0-100 lead score (Automate)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation?

  @@index([clientId])
  @@index([clientId, status])
  @@index([clientId, createdAt])
  @@map("leads")
}

model Booking {
  id         String        @id @default(cuid())
  clientId   String
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  status     BookingStatus @default(REQUESTED)

  serviceName String
  startAt     DateTime
  endAt       DateTime
  notes       String?

  // Paid-booking / deposit support (Automate).
  depositRequired Boolean  @default(false)
  depositInvoiceId String? @unique
  depositInvoice   Invoice? @relation("BookingDeposit", fields: [depositInvoiceId], references: [id])
  invoices         Invoice[] @relation("BookingInvoices") // invoices/estimates raised for this appointment

  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clientId])
  @@index([clientId, startAt])
  @@index([clientId, status])
  @@map("bookings")
}

/// Central catalog of services a client offers — the single source of truth wired into the
/// appointments scheduler (title + typical duration) and the website services section, and
/// reusable by invoices. The system-created `isDefault` "Other" row is hidden from the website
/// but selectable in appointments/invoices, and cannot be deleted.
model Service {
  id              String  @id @default(cuid())
  clientId        String
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  icon            String? // lucide icon key (backend identifier)
  durationMinutes Int     @default(60) // typical time to complete
  price           Int? // cents, optional — used by invoices later

  showOnWebsite   Boolean @default(true)
  isDefault       Boolean @default(false) // the "Other" catch-all — not on the website, not deletable
  sortOrder       Int     @default(0)
  active          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, active])
  @@map("services")
}

model Conversation {
  id         String              @id @default(cuid())
  clientId   String
  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?           @relation(fields: [customerId], references: [id])
  leadId     String?             @unique
  lead       Lead?               @relation(fields: [leadId], references: [id])
  channel    ConversationChannel @default(WEBSITE_CHAT)
  status     String              @default("open") // open, escalated, closed
  subject    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  aiConversation AiConversation?

  @@index([clientId])
  @@index([clientId, status])
  @@map("conversations")
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     MessageSenderType
  senderId       String? // user/customer id depending on type
  body           String
  // For AI-drafted messages awaiting human approval (suggestion mode).
  isDraft        Boolean           @default(false)
  approvedById   String?
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@map("messages")
}

model SupportTicket {
  id         String         @id @default(cuid())
  // Most tickets are about a client; clientId null = internal/company ticket.
  clientId   String?
  client     Client?        @relation(fields: [clientId], references: [id])
  subject    String
  body       String
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(NORMAL)
  assignedToId String?
  openedById   String?
  aiSummary    String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  comments TicketComment[]

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model TicketComment {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  body       String
  internal   Boolean       @default(false) // internal note vs client-visible
  attachmentUrl String?
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_comments")
}

// =============================================================================
// PAYMENTS / INVOICES / STATEMENTS — centralized dual-purpose ledger
// =============================================================================

model Invoice {
  id         String        @id @default(cuid())
  kind       InvoiceKind
  docType    FinanceDocType @default(INVOICE) // ESTIMATE | QUOTE | INVOICE (client→customer docs)
  clientId   String // ledger owner: tenant whose books this belongs to
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Set only for CLIENT_CUSTOMER invoices (a client billing its customer).
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])

  number     String // unique per client (see @@unique below)
  status     InvoiceStatus @default(DRAFT)
  currency   String        @default("usd")

  // Money (all integer cents). subtotal = sum of line amounts (post line-discount, pre invoice
  // discount); discountTotal = invoice-level discount; tax = sum of line tax; total = subtotal -
  // discountTotal + tax. amountPaid accumulates payments.
  subtotal      Int           @default(0)
  discountType  DiscountType?
  discountValue Int           @default(0) // PERCENT → basis points, FIXED → cents
  discountTotal Int           @default(0)
  tax           Int           @default(0)
  total         Int           @default(0)
  amountPaid    Int           @default(0)
  depositAmount Int           @default(0) // requested up-front deposit, cents

  notes String?
  terms String?

  issueDate  DateTime?
  dueDate    DateTime?
  expiresAt  DateTime? // estimate/quote expiry
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  declinedAt DateTime?
  paidAt     DateTime?

  // Conversion chain: ESTIMATE → QUOTE → INVOICE.
  convertedFromId String?  @unique
  convertedFrom   Invoice? @relation("InvoiceConversion", fields: [convertedFromId], references: [id])
  convertedTo     Invoice? @relation("InvoiceConversion")

  publicToken String? @unique // customer-facing hosted view token

  stripeInvoiceId    String?
  taxCalculationId   String? // Stripe Tax calculation id (automatic tax) — used to file the transaction on payment

  // Payment-reminder bookkeeping (worker-driven): when we last emailed a reminder and how many we've
  // sent, so the sweep fires at most one per day per the owner's reminder schedule.
  lastReminderAt DateTime?
  reminderCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // General appointment link (distinct from the 1:1 deposit relation below): the appointment this
  // invoice/estimate was raised for, so the appointment can show whether it's been invoiced/sent/paid.
  bookingId String?
  booking   Booking? @relation("BookingInvoices", fields: [bookingId], references: [id])

  // The recurring plan that generated this invoice (null for one-off documents).
  recurringPlanId String?
  recurringPlan   RecurringPlan? @relation(fields: [recurringPlanId], references: [id])

  lineItems    InvoiceLineItem[]
  payments     Payment[]
  refunds      Refund[]
  paymentLinks PaymentLink[]
  bookingDeposit Booking? @relation("BookingDeposit")

  @@unique([clientId, number])
  @@index([clientId])
  @@index([clientId, docType, status])
  @@index([clientId, status])
  @@index([kind])
  @@index([bookingId])
  @@index([recurringPlanId])
  @@map("invoices")
}

// =============================================================================
// RECURRING SERVICE PLANS — repeat billing (lawn care, cleaning, retainers, …)
// =============================================================================

enum RecurringInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// INVOICE = generate + email an invoice (with a pay link) each period.
// AUTO_CHARGE = charge a saved card off-session each period (falls back to a pay link until a card
// is on file / Stripe is live).
enum RecurringMode {
  INVOICE
  AUTO_CHARGE
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  ENDED
}

model RecurringPlan {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title    String
  mode     RecurringMode     @default(INVOICE)
  interval RecurringInterval @default(MONTHLY)
  status   RecurringStatus   @default(ACTIVE)

  lineItems Json   // [{ description, quantity, unitAmount, serviceId?, taxRateId? }]
  currency  String @default("usd")
  notes     String?
  dueDays   Int    @default(14) // INVOICE mode: due N days after each generation

  nextRunAt   DateTime
  lastRunAt   DateTime?
  occurrences Int       @default(0)

  // AUTO_CHARGE: card saved on file (set once the customer pays the first pay link with save-card on).
  stripeCustomerId      String?
  stripePaymentMethodId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([clientId])
  @@index([status, nextRunAt])
  @@index([customerId])
  @@map("recurring_plans")
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   String? // soft reference to the Services catalog (provenance; not FK-enforced)
  description String
  quantity    Int     @default(1)
  unitAmount  Int     @default(0) // cents

  // Per-line discount + tax (snapshots so deleting a rate/service can't corrupt totals).
  discountType  DiscountType?
  discountValue Int           @default(0) // PERCENT → basis points, FIXED → cents
  taxRateId     String?
  taxRateBps    Int           @default(0) // snapshot of the rate at line time
  taxAmount     Int           @default(0) // computed cents
  amount        Int           @default(0) // qty * unit − line discount (pre-tax)
  position      Int           @default(0)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

// Client-defined sales-tax rates (manual). Architected so Stripe Tax can replace the source later.
model TaxRate {
  id        String  @id @default(cuid())
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  rateBps   Int // basis points, e.g. 850 = 8.50%
  inclusive Boolean @default(false)
  isDefault Boolean @default(false)
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("tax_rates")
}

model Payment {
  id         String          @id @default(cuid())
  clientId   String
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?       @relation(fields: [customerId], references: [id])
  invoiceId  String?
  invoice    Invoice?        @relation(fields: [invoiceId], references: [id])

  provider   PaymentProvider @default(STRIPE)
  status     PaymentStatus   @default(PENDING)
  amount     Int // cents
  currency   String          @default("usd")

  stripePaymentIntentId String?  @unique
  stripeChargeId        String?
  receiptUrl            String?

  failureReason String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refunds Refund[]

  @@index([clientId])
  @@index([invoiceId])
  @@index([status])
  @@map("payments")
}

model PaymentMethod {
  id         String   @id @default(cuid())
  clientId   String
  customerId String?
  // Never store raw card data — only Stripe references.
  stripePaymentMethodId String
  brand      String?
  last4      String?
  expMonth   Int?
  expYear    Int?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([customerId])
  @@map("payment_methods")
}

model PaymentLink {
  id         String    @id @default(cuid())
  clientId   String
  invoiceId  String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id])
  url        String
  stripePaymentLinkId String?
  amount     Int
  currency   String    @default("usd")
  expiresAt  DateTime?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([clientId])
  @@index([invoiceId])
  @@map("payment_links")
}

// Raw Stripe webhook events, stored for idempotency and audit.
model PaymentEvent {
  id            String   @id @default(cuid())
  provider      PaymentProvider @default(STRIPE)
  externalId    String   @unique // Stripe event id — dedupes webhook retries
  type          String // e.g. "payment_intent.succeeded"
  payload       Json
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([type])
  @@map("payment_events")
}

model Refund {
  id         String       @id @default(cuid())
  paymentId  String
  payment    Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId  String?
  invoice    Invoice?     @relation(fields: [invoiceId], references: [id])
  amount     Int
  reason     String?
  status     RefundStatus @default(PENDING)
  // Refunds require human approval — never AI-initiated.
  approvedById String?
  stripeRefundId String?
  createdAt  DateTime     @default(now())

  @@index([paymentId])
  @@map("refunds")
}

model Statement {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  // Snapshot of computed figures at generation time.
  data       Json // open invoices, paid invoices, balance, payment history
  pdfUrl     String?
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([customerId])
  @@map("statements")
}

model Due {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?
  invoiceId  String?
  amount     Int
  dueDate    DateTime
  settled    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([dueDate])
  @@map("dues")
}

model AccountBalance {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customerId String?  @unique
  customer   Customer? @relation(fields: [customerId], references: [id])
  balance    Int      @default(0) // cents owed; negative = credit
  updatedAt  DateTime @updatedAt

  @@index([clientId])
  @@map("account_balances")
}

// =============================================================================
// AI — central service
// =============================================================================

model AiKnowledgeBase {
  id        String   @id @default(cuid())
  clientId  String   @unique
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Approved business facts the AI may answer from — nothing outside this.
  data      Json // { services, areas, hours, pricing, faqs, policies, tone... }
  mode      AiMode   @default(SUGGESTION)
  updatedAt DateTime @updatedAt

  prompts AiPrompt[]

  @@map("ai_knowledge_bases")
}

model AiPrompt {
  id              String          @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   AiKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  key             String // "chat_reply", "lead_summary", "invoice_reminder"...
  template        String
  version         Int             @default(1)
  active          Boolean         @default(true)

  @@index([knowledgeBaseId])
  @@map("ai_prompts")
}

model AiConversation {
  id             String        @id @default(cuid())
  clientId       String
  conversationId String?       @unique // links to the customer-facing Conversation
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  mode           AiMode
  createdAt      DateTime      @default(now())

  messages    AiMessage[]
  actions     AiAction[]
  escalations AiEscalation[]

  @@index([clientId])
  @@map("ai_conversations")
}

model AiMessage {
  id               String         @id @default(cuid())
  aiConversationId String
  aiConversation   AiConversation @relation(fields: [aiConversationId], references: [id], onDelete: Cascade)
  role             String // "system", "user", "assistant"
  content          String
  confidence       Float?
  createdAt        DateTime       @default(now())

  @@index([aiConversationId])
  @@map("ai_messages")
}

// Record of an action the AI took or proposed, plus its approval state.
model AiAction {
  id               String       @id @default(cuid())
  aiConversationId String?
  aiConversation   AiConversation? @relation(fields: [aiConversationId], references: [id])
  clientId         String
  type             AiActionType
  status           String       @default("proposed") // proposed, approved, executed, rejected
  payload          Json
  approvedById     String? // sensitive actions require human approval
  executedAt       DateTime?
  createdAt        DateTime     @default(now())

  @@index([clientId])
  @@index([type])
  @@map("ai_actions")
}

model AiEscalation {
  id               String             @id @default(cuid())
  aiConversationId String?
  aiConversation   AiConversation?    @relation(fields: [aiConversationId], references: [id])
  clientId         String
  reason           AiEscalationReason
  resolved         Boolean            @default(false)
  notifiedAt       DateTime?
  createdAt        DateTime           @default(now())

  @@index([clientId])
  @@index([resolved])
  @@map("ai_escalations")
}

model AiUsageLog {
  id         String   @id @default(cuid())
  clientId   String
  type       AiActionType
  model      String
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  costCents    Int    @default(0)
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([clientId, createdAt])
  @@map("ai_usage_logs")
}

// =============================================================================
// COMMUNICATION
// =============================================================================

model EmailLog {
  id         String         @id @default(cuid())
  clientId   String? // null = platform-originated email
  toEmail    String
  fromEmail  String
  subject    String
  template   String?
  status     DeliveryStatus @default(QUEUED)
  providerId String? // Resend message id
  error      String?
  createdAt  DateTime       @default(now())

  @@index([clientId])
  @@index([status])
  @@map("email_logs")
}

model SmsLog {
  id         String         @id @default(cuid())
  clientId   String?
  toPhone    String
  body       String
  status     DeliveryStatus @default(QUEUED)
  providerId String? // Twilio sid
  // Send is blocked unless consent verified — recorded here for audit.
  consentVerified Boolean   @default(false)
  error      String?
  createdAt  DateTime       @default(now())

  @@index([clientId])
  @@index([status])
  @@map("sms_logs")
}

model NotificationEvent {
  id        String              @id @default(cuid())
  clientId  String?
  event     String // e.g. "lead.created", "invoice.paid"
  channel   NotificationChannel
  recipientId String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([clientId])
  @@index([event])
  @@index([clientId, event])
  @@index([recipientId])
  @@map("notification_events")
}

// =============================================================================
// ANALYTICS
// =============================================================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  name      String // "lead_created", "booking_created", "payment_succeeded"...
  properties Json?
  occurredAt DateTime @default(now())

  @@index([clientId])
  @@index([name])
  @@index([clientId, occurredAt])
  @@map("analytics_events")
}

model WebsiteVisit {
  id        String   @id @default(cuid())
  websiteId String
  website   Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  path      String
  referrer  String?
  userAgent String?
  visitedAt DateTime @default(now())

  @@index([websiteId])
  @@index([websiteId, visitedAt])
  @@map("website_visits")
}

model ConversionEvent {
  id        String   @id @default(cuid())
  clientId  String?
  type      String // "lead", "booking", "payment", "signup"
  value     Int?    // optional monetary value in cents
  sourcePath String?
  occurredAt DateTime @default(now())

  @@index([clientId])
  @@index([type])
  @@map("conversion_events")
}
