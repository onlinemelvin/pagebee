# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma Migrate only.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Root domain for tenant subdomain routing. Tenant sites live at {slug}.<root>.
# Local: "localhost:3000" (browsers resolve *.localhost). Prod: "pagebee.com".
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
# Shared secret for /api/v1/internal/* (jobs, webhooks dispatch).
INTERNAL_API_SECRET="change-me"
# Protects the scheduled cron routes (e.g. custom-domain verification). Vercel Cron attaches
# `Authorization: Bearer <CRON_SECRET>` automatically when this is set in the project. The cron
# endpoint fails closed: with neither CRON_SECRET nor INTERNAL_API_SECRET set it refuses to run.
CRON_SECRET=""

# ── Vercel Domains API (custom domains for Connect/Automate) ─────────────────
# Provisions tenant custom domains on the Vercel project (add → verify → SSL). Leave unset for
# dev: the approval flow still shows DNS records but verification is manual (no live polling).
# Token: Vercel → Account Settings → Tokens (scope it to the team/project). IDs: Project →
# Settings → General (VERCEL_PROJECT_ID); Team → Settings (VERCEL_TEAM_ID, omit for personal).
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# ── Domain purchasing (Vercel Registrar API — "buy a brand new domain" path) ─
# PageBee can register a domain for a client through the Vercel registrar (same VERCEL_TOKEN).
# PageBee absorbs the cost, so spend is gated: a quote at or under the cap is auto-approved and
# bought; over the cap goes to the admin price-review queue. Cents (2000 = $20.00/yr).
DOMAIN_PRICE_CAP_CENTS="2000"
# Registrant (WHOIS) contact used for domains PageBee buys — the platform owns these registrations.
# Required to buy; a purchase fails closed if any are missing. Phone is E.164 with a dot: +1.5551234567
REGISTRANT_FIRST_NAME=""
REGISTRANT_LAST_NAME=""
REGISTRANT_EMAIL=""
REGISTRANT_PHONE=""
REGISTRANT_ADDRESS1=""
REGISTRANT_CITY=""
REGISTRANT_STATE=""
REGISTRANT_ZIP=""
REGISTRANT_COUNTRY="US"
REGISTRANT_COMPANY=""
# Website generation worker: leave unset for dev (the API processes inline). In prod
# set to "external" so the API only enqueues and the `npm run worker` process handles it.
GENERATION_WORKER=""
# Vercel-safe generation offload: on Vercel the long HTML Claude call can't run in a 60s function,
# so it's offloaded to a Supabase Edge Function. Set this to that function's URL and the prepare
# phase will hand the call off to it. Leave blank for local/worker (inline) generation.
#   e.g. https://<project-ref>.supabase.co/functions/v1/generate-website
# The edge function authenticates with INTERNAL_API_SECRET (above) and calls back the finalize
# route at NEXT_PUBLIC_APP_URL. Deploy: supabase functions deploy generate-website --no-verify-jwt
GENERATION_EDGE_URL=""
# Optional demo video shown on the create-site welcome screen.
NEXT_PUBLIC_DEMO_VIDEO_URL=""

# ── Rate limiting (Upstash Redis REST) ───────────────────────────────────────
# Without these the public-endpoint limiter uses an in-memory fallback that counts
# per serverless instance. Set both in prod for correct cross-instance limiting on
# Vercel. Free database + REST creds from upstash.com. The limiter fails open.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Signed-token secrets ─────────────────────────────────────────────────────
# HMAC secret binding the Stripe Connect OAuth `state` to a client (anti-CSRF).
# Falls back to SUPABASE_SERVICE_ROLE_KEY if unset; set an explicit one in prod.
STRIPE_CONNECT_STATE_SECRET=""
# Signs per-client iCal booking feed URLs. Falls back to SUPABASE_SERVICE_ROLE_KEY.
ICAL_FEED_SECRET=""

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Leave blank in dev — the email service falls back to console logging.
RESEND_API_KEY=""
# From must be on a Resend-VERIFIED domain (gmail/outlook addresses are rejected).
RESEND_FROM_EMAIL="PageBee <noreply@pagebee.com>"
# Optional global reply-to — handy to route replies to a real inbox while the
# sending domain is still a placeholder. Per-send replyTo overrides it.
RESEND_REPLY_TO=""
# Public URL of the logo shown in email headers. Email clients can't load
# localhost, so point this at a public copy (e.g. a Supabase public bucket) in
# dev. Unset in prod = derived from NEXT_PUBLIC_APP_URL + /logo/pagebee-logo.png.
NEXT_PUBLIC_EMAIL_LOGO_URL=""
# Shared, Resend-VERIFIED domain that client→customer email sends from when a
# client has no verified domain of their own (From shows the business name).
# Unset = mail.<NEXT_PUBLIC_ROOT_DOMAIN>, falling back to the RESEND_FROM_EMAIL
# domain on localhost so dev sends deliver.
CUSTOMER_MAIL_DOMAIN=""
# Secret for signing stateless customer unsubscribe tokens. Falls back to
# INTERNAL_API_SECRET when unset.
EMAIL_TOKEN_SECRET=""
# Svix signing secret for the Resend webhook (delivery/open/bounce tracking).
# Set this in prod and point Resend's webhook at /api/v1/webhooks/resend.
# Unset = signature check is skipped (dev only).
RESEND_WEBHOOK_SECRET=""

# ── Supabase (Auth / Storage) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Seed admin (created in Supabase Auth + linked to a platform User by `npm run db:seed`).
ADMIN_EMAIL="admin@pagebee.com"
ADMIN_PASSWORD="change-me-strong-password"

# ── AI (Claude / Anthropic) ─────────────────────────────────────────────────
# Used for website generation. Leave blank to use the deterministic stub generator.
ANTHROPIC_API_KEY=""
# Model tiers. QUALITY handles the user-facing website HTML (build + surgical edits); CHEAP
# handles trivial structured calls (config copy, service icon/description, image triage).
ANTHROPIC_MODEL="claude-sonnet-4-6"        # quality tier; bump to claude-opus-4-8 for max quality
ANTHROPIC_MODEL_CHEAP="claude-haiku-4-5"   # cheap tier for trivial calls
# Set to "true" to skip ALL paid AI calls and use the deterministic stubs — free local testing
# of layout / serve pipeline / dashboard without burning credits.
AI_FORCE_STUB=""

# Gate the one-time setup-fee payment step before a site launches. Leave off ("" / not "true")
# until card payments are wired up — approving a preview then launches the site immediately.
SETUP_FEE_ENABLED=""

# 21st.dev Magic MCP (Phase 2 — component generation). From the 21st.dev Magic Console.
MAGIC_API_KEY=""

# Pexels (royalty-free stock photos for generated sites). Free key from pexels.com/api.
# Optional — without it, generated sites use tasteful CSS backgrounds instead of photos.
PEXELS_API_KEY=""

# ── Stripe (finance Phase 2 — use TEST keys for now) ─────────────────────────
# Platform secret key (sk_test_…). Enables Connect onboarding, checkout, webhooks.
STRIPE_SECRET_KEY=""
# Publishable key (pk_test_…) — needed client-side for embedded PageBee Pay onboarding.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret (whsec_…) for POST /api/v1/webhooks/stripe (Connect/payments).
STRIPE_WEBHOOK_SECRET=""
# Separate webhook signing secret (whsec_…) for POST /api/v1/webhooks/stripe-billing
# (platform subscriptions + setup fees). This is a DIFFERENT endpoint/secret than above.
STRIPE_BILLING_WEBHOOK_SECRET=""
# Connect OAuth client id (ca_…) — required for "bring your own Stripe" (Connect Standard).
# From Dashboard → Settings → Connect → OAuth. Set the redirect URI to
# {NEXT_PUBLIC_APP_URL}/api/v1/client/payments/connect/oauth
STRIPE_CONNECT_CLIENT_ID=""
# Platform application fee in basis points charged on every payment (200 = 2.00%). Optional.
STRIPE_PLATFORM_FEE_BPS="200"
# Refund policy: on a refund we always reverse the transfer (the merchant funds their own refund).
# Set "true" to ALSO return the platform application fee to the merchant; default keeps the fee
# (we did the processing work). See refundPayment() in payments/service.ts.
STRIPE_REFUND_APPLICATION_FEE=""
# Publishable key (NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY above) also powers the embedded Payment Element
# for invoice pay + card-on-file authorization (white-label card entry, PCI SAQ A).
