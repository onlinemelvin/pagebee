# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection (PgBouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma Migrate only.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Root domain for tenant subdomain routing. Tenant sites live at {slug}.<root>.
# Local: "localhost:3000" (browsers resolve *.localhost). Prod: "pagebee.com".
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
# Shared secret for /api/v1/internal/* (jobs, webhooks dispatch).
INTERNAL_API_SECRET="change-me"
# Website generation worker: leave unset for dev (the API processes inline). In prod
# set to "external" so the API only enqueues and the `npm run worker` process handles it.
GENERATION_WORKER=""

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Leave blank in dev — the email service falls back to console logging.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="PageBee <noreply@pagebee.com>"

# ── Supabase (Auth / Storage) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Seed admin (created in Supabase Auth + linked to a platform User by `npm run db:seed`).
ADMIN_EMAIL="admin@pagebee.com"
ADMIN_PASSWORD="change-me-strong-password"

# ── AI (Claude / Anthropic) ─────────────────────────────────────────────────
# Used for website generation. Leave blank to use the deterministic stub generator.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"  # cheaper option: claude-sonnet-4-6

# 21st.dev Magic MCP (Phase 2 — component generation). From the 21st.dev Magic Console.
MAGIC_API_KEY=""

# Pexels (royalty-free stock photos for generated sites). Free key from pexels.com/api.
# Optional — without it, generated sites use tasteful CSS backgrounds instead of photos.
PEXELS_API_KEY=""

# ── Stripe (finance Phase 2 — use TEST keys for now) ─────────────────────────
# Platform secret key (sk_test_…). Enables Connect onboarding, checkout, webhooks.
STRIPE_SECRET_KEY=""
# Publishable key (pk_test_…) — needed client-side for embedded PageBee Pay onboarding.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret (whsec_…) for POST /api/v1/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=""
# Connect OAuth client id (ca_…) — required for "bring your own Stripe" (Connect Standard).
# From Dashboard → Settings → Connect → OAuth. Set the redirect URI to
# {NEXT_PUBLIC_APP_URL}/api/v1/client/payments/connect/oauth
STRIPE_CONNECT_CLIENT_ID=""
# Platform application fee in basis points charged on every payment (200 = 2.00%). Optional.
STRIPE_PLATFORM_FEE_BPS="200"
